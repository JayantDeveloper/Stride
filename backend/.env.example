# ─────────────────────────────────────────────────────────────
#  focus-exec — Backend Environment Variables
#  Copy this file to .env and fill in your values:
#    cp .env.example .env
# ─────────────────────────────────────────────────────────────


# ── Google OAuth / Calendar ───────────────────────────────────
#
#  Setup steps:
#  1. Go to https://console.cloud.google.com/
#  2. Create a project (or select an existing one)
#  3. Enable the "Google Calendar API" under APIs & Services → Library
#  4. Go to APIs & Services → Credentials → Create Credentials → OAuth 2.0 Client IDs
#  5. Application type: Web application
#  6. Add Authorized redirect URI: http://localhost:5001/api/auth/google/callback
#  7. Copy the Client ID and Client Secret below
#  8. In the app, go to Settings → Connect Google Calendar to complete OAuth

GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_REDIRECT_URI=http://localhost:5001/api/auth/google/callback


# ── OpenAI ────────────────────────────────────────────────────
#
#  Get your API key at: https://platform.openai.com/api-keys
#  Used for: slot suggestions, daily planning, check-in responses, evening reviews
#  Model: gpt-4o
#  The app works without this key — AI buttons will just return errors.

OPENAI_API_KEY=your_openai_api_key_here


# ── Session Security ──────────────────────────────────────────
#
#  Used to sign the express-session cookie.
#  Change this to any random string — it just needs to be secret.
#  Example: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"

SESSION_SECRET=change-me-to-a-long-random-secret-string


# ── Server ────────────────────────────────────────────────────

PORT=5001
